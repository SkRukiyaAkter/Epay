# Flask / App
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars
JWT_SECRET=change-me-to-a-random-jwt-secret
SERVER_HMAC_SECRET=change-me-to-a-random-hmac-secret
OFFICER_API_KEY=change-me-to-a-random-officer-key
FLASK_DEBUG=1

# Database (Supabase Session Pooler - IPv4)
DATABASE_URL=postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require

# Redis (optional - token blacklist)
REDIS_URL=redis://localhost:6379/0
